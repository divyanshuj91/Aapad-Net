<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aapad-Net | Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-gray-900 text-white min-h-screen p-4">

    <div class="mb-8 flex flex-col sm:flex-row sm:justify-between sm:items-end gap-5 border-b border-gray-800 pb-5">

        <div>
            <h1 class="text-2xl sm:text-3xl font-bold text-white flex items-center gap-3">
                <svg class="w-8 h-8 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4">
                    </path>
                </svg>
                Aapad-Net Control Panel
            </h1>
            <p class="text-gray-400 text-sm mt-1">Live Emergency Requests & Operations</p>
        </div>

        <div class="flex items-center gap-3 w-full sm:w-auto">

            <a href="/admin"
                class="flex-1 sm:flex-none flex justify-center items-center gap-2 bg-gray-800 border border-gray-700 hover:bg-gray-700 text-blue-400 hover:text-blue-300 px-5 py-2.5 rounded-xl text-sm font-semibold transition shadow-sm">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                    </path>
                </svg>
                Refresh
            </a>

            <a href="/logout"
                class="flex-1 sm:flex-none flex justify-center items-center gap-2 bg-red-500/10 border border-red-500/20 hover:bg-red-600 text-red-500 hover:text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition shadow-sm group">
                <svg class="w-4 h-4 group-hover:text-white transition-colors" fill="none" stroke="currentColor"
                    viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1">
                    </path>
                </svg>
                Logout
            </a>
        </div>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-6">

        <div class="bg-green-600 rounded-xl p-4 text-center">
            <p class="text-sm opacity-80">Safe</p>
            <p class="text-2xl font-bold">
                <%= safeCount %>
            </p>
        </div>

        <div class="bg-red-600 rounded-xl p-4 text-center">
            <p class="text-sm opacity-80">Critical</p>
            <p class="text-2xl font-bold">
                <%= criticalCount %>
            </p>
        </div>

        <div class="bg-yellow-500 text-black rounded-xl p-4 text-center">
            <p class="text-sm opacity-80">High</p>
            <p class="text-2xl font-bold">
                <%= highCount %>
            </p>
        </div>

        <div class="bg-gray-700 rounded-xl p-4 text-center">
            <p class="text-sm opacity-80">Total</p>
            <p class="text-2xl font-bold">
                <%= requests.length %>
            </p>
        </div>

    </div>
    <!-- View Toggle Dropdown -->
    <div class="mb-6 flex justify-end items-center border-b border-gray-800 pb-4">
        <select id="view-selector" class="bg-gray-800 border border-gray-700 text-white text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block p-2.5 outline-none cursor-pointer shadow-lg w-full md:w-auto">
            <option value="emergency">🚨 Emergency Requests</option>
            <option value="hazards">⚠️ Hazard Reports</option>
        </select>
    </div>

    <!-- Emergency Requests Section -->
    <div id="emergency-section">
        <div class="mb-4">
            <h2 class="text-2xl font-bold border-b border-gray-700 pb-2 text-white">Emergency Requests</h2>
        </div>
        <div class="space-y-4 mb-20">

        <% if (!requests || requests.length===0) { %>
            <div class="bg-gray-800 p-6 rounded-xl text-center text-gray-400">
                No active requests.
            </div>
            <% } else { %>
                <% requests.forEach(request=> { %>
                    <div
                        class="bg-gray-800 rounded-2xl p-5 shadow-lg border border-gray-700 flex flex-col md:flex-row gap-6">
                        <div class="flex-1">
                            <div class="flex flex-col sm:flex-row sm:justify-between items-start gap-3 sm:gap-4 break-words overflow-hidden">
                                <div class="max-w-full">
                                    <h2 class="text-xl font-semibold break-words">
                                        <%= request.name %>
                                    </h2>
                                    <p class="text-sm text-gray-400">
                                        <%= new Date(request.created_at.replace(' ', 'T') + 'Z'
                                            ).toLocaleString('en-US', { dateStyle: 'medium' , timeStyle: 'short' }) %>
                                    </p>
                                </div>

                                <div class="flex flex-wrap sm:flex-col items-start sm:items-end gap-2 mt-2 sm:mt-0 whitespace-nowrap">
                                    <% if (request.urgency==="critical" ) { %>
                                        <span class="bg-red-600 px-3 py-1 text-sm rounded-full">Critical</span>
                                        <% } else if (request.urgency==="high" ) { %>
                                            <span class="bg-yellow-500 text-black px-3 py-1 text-sm rounded-full">High</span>
                                            <% } else { %>
                                                <span class="bg-gray-500 text-white px-3 py-1 text-sm rounded-full">Normal</span>
                                                <% } %>

                                                    <% if (request.status==='in_progress' ) { %>
                                                        <span class="bg-blue-600 px-3 py-1 text-sm rounded-full">In Progress</span>
                                                        <% } else if (request.status==='resolved' ) { %>
                                                            <span class="bg-green-600 px-3 py-1 text-sm rounded-full">Resolved</span>
                                                            <% } else { %>
                                                                <span class="bg-gray-600 px-3 py-1 text-sm rounded-full">Pending</span>
                                                                <% } %>
                                </div>
                            </div>

                            <div class="mt-4 text-sm text-gray-300 space-y-1">
                                <p><strong>Type:</strong>
                                    <%= request.type %>
                                </p>
                                <p><strong>Phone:</strong>
                                    <%= request.phone || "Not provided" %>
                                </p>
                                <p><strong>Location:</strong>
                                    <%= request.location || "Unknown" %>
                                </p>
                            </div>

                            <div class="mt-4 flex flex-col sm:flex-row gap-2 sm:gap-3 flex-wrap">
                                <% if (request.status !=='in_progress' && request.status !=='resolved' ) { %>
                                    <button onclick="updateStatus('<%= request.id %>', 'in_progress')"
                                        class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm transition text-center whitespace-nowrap">
                                        Mark In Progress
                                    </button>
                                    <% } %>
                                        <% if (request.status !=='resolved' ) { %>
                                            <button onclick="updateStatus('<%= request.id %>', 'resolved')"
                                                class="w-full sm:w-auto bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm transition text-center whitespace-nowrap">
                                                Mark Resolved
                                            </button>
                                            <% } else { %>
                                                <button onclick="deleteRequest('<%= request.id %>')"
                                                    class="w-full sm:w-auto bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg text-sm transition text-center whitespace-nowrap">
                                                    Delete Request
                                                </button>
                                                <% } %>
                            </div>
                        </div>

                        <% if (request.image) { %>
                            <div
                                class="w-full md:w-48 shrink-0 overflow-hidden rounded-xl border border-gray-700 mt-4 md:mt-0 flex items-center justify-center bg-gray-900">
                                <img src="/uploads/<%= request.image %>"
                                    class="w-full h-full object-cover max-h-48 md:max-h-full" alt="Request Image">
                            </div>
                            <% } %>
                    </div>
                    <% }) %>
                        <% } %>

        </div> <!-- End space-y for emergency -->
    </div> <!-- End emergency-section -->

    <!-- Hazard Reports Section -->
    <div id="hazards-section" class="hidden">
        <div class="mb-4">
            <h2 class="text-2xl font-bold border-b border-gray-700 pb-2 text-yellow-500 flex items-center gap-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                    </path>
                </svg>
                Hazard Reports
            </h2>
        </div>
        <div class="space-y-4 mb-20">
        <% if (!hazards || hazards.length===0) { %>
            <div class="bg-gray-800 p-6 rounded-xl text-center text-gray-400">
                No active hazard reports.
            </div>
            <% } else { %>
                <% hazards.forEach(hazard=> { %>
                    <div
                        class="bg-gray-800 rounded-2xl p-5 shadow-lg border border-gray-700 flex flex-col md:flex-row gap-6">
                        <div class="flex-1">
                            <div class="flex flex-col sm:flex-row sm:justify-between items-start gap-3 sm:gap-4 break-words overflow-hidden">
                                <div class="max-w-full">
                                    <h2 class="text-xl font-semibold break-words">
                                        Hazard Report #<%= hazard.id %>
                                    </h2>
                                    <p class="text-sm text-gray-400">
                                        <%= new Date(hazard.created_at.replace(' ', 'T') + 'Z'
                                            ).toLocaleString('en-US', { dateStyle: 'medium' , timeStyle: 'short' }) %>
                                    </p>
                                </div>
                                <div class="flex flex-wrap sm:flex-col items-start sm:items-end gap-2 mt-2 sm:mt-0 whitespace-nowrap">
                                    <% if (hazard.status==='in_progress' ) { %>
                                        <span class="bg-blue-600 px-3 py-1 text-sm rounded-full">In Progress</span>
                                        <% } else if (hazard.status==='resolved' ) { %>
                                            <span class="bg-green-600 px-3 py-1 text-sm rounded-full">Resolved</span>
                                            <% } else { %>
                                                <span class="bg-gray-600 px-3 py-1 text-sm rounded-full">Pending</span>
                                                <% } %>
                                </div>
                            </div>

                            <div class="mt-4 text-sm text-gray-300 space-y-1">
                                <p><strong>Location:</strong>
                                    <%= hazard.location %>
                                </p>
                                <p><strong>Description:</strong>
                                    <%= hazard.description %>
                                </p>
                            </div>

                            <div class="mt-4 flex flex-col sm:flex-row gap-2 sm:gap-3 flex-wrap">
                                <% if (hazard.status !=='in_progress' && hazard.status !=='resolved' ) { %>
                                    <button onclick="updateHazardStatus('<%= hazard.id %>', 'in_progress')"
                                        class="w-full sm:w-auto bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm transition text-center whitespace-nowrap">
                                        Mark In Progress
                                    </button>
                                    <% } %>
                                        <% if (hazard.status !=='resolved' ) { %>
                                            <button onclick="updateHazardStatus('<%= hazard.id %>', 'resolved')"
                                                class="w-full sm:w-auto bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm transition text-center whitespace-nowrap">
                                                Mark Resolved
                                            </button>
                                            <% } else { %>
                                                <button onclick="deleteHazard('<%= hazard.id %>')"
                                                    class="w-full sm:w-auto bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg text-sm transition text-center whitespace-nowrap">
                                                    Delete Hazard
                                                </button>
                                                <% } %>
                            </div>
                        </div>

                        <% if (hazard.image) { %>
                            <div
                                class="w-full md:w-48 shrink-0 overflow-hidden rounded-xl border border-gray-700 mt-4 md:mt-0 flex items-center justify-center bg-gray-900">
                                <img src="/uploads/<%= hazard.image %>"
                                    class="w-full h-full object-cover max-h-48 md:max-h-full" alt="Hazard Image">
                            </div>
                            <% } %>
                    </div>
                    <% }) %>
                        <% } %>
        </div> <!-- End space-y for hazards -->
    </div> <!-- End hazards-section -->

</body>
<script src="https://cdn.tailwindcss.com"></script>
<script>
    document.getElementById('view-selector').addEventListener('change', function(e) {
        const val = e.target.value;
        if (val === 'emergency') {
            document.getElementById('emergency-section').classList.remove('hidden');
            document.getElementById('hazards-section').classList.add('hidden');
        } else {
            document.getElementById('emergency-section').classList.add('hidden');
            document.getElementById('hazards-section').classList.remove('hidden');
        }
    });

    async function updateStatus(id, status) {
        if (!confirm(`Are you sure you want to mark this request as ${status.replace('_', ' ')}?`)) return;

        try {
            const res = await fetch(`/admin/request/${id}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to update status');
            }
        } catch (error) {
            console.error(error);
            alert('Error updating status');
        }
    }

    async function deleteRequest(id) {
        if (!confirm('Are you sure you want to delete this request permanently?')) return;

        try {
            const res = await fetch(`/admin/request/${id}`, {
                method: 'DELETE',
            });
            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to delete request');
            }
        } catch (error) {
            console.error(error);
            alert('Error deleting request');
        }
    }

    async function updateHazardStatus(id, status) {
        if (!confirm(`Are you sure you want to mark this hazard as ${status.replace('_', ' ')}?`)) return;

        try {
            const res = await fetch(`/admin/hazard/${id}/status`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ status })
            });
            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to update hazard status');
            }
        } catch (error) {
            console.error(error);
            alert('Error updating hazard status');
        }
    }

    async function deleteHazard(id) {
        if (!confirm('Are you sure you want to delete this hazard permanently?')) return;

        try {
            const res = await fetch(`/admin/hazard/${id}`, {
                method: 'DELETE',
            });
            const data = await res.json();
            if (data.success) {
                location.reload();
            } else {
                alert('Failed to delete hazard');
            }
        } catch (error) {
            console.error(error);
            alert('Error deleting hazard');
        }
    }
</script>

</html>