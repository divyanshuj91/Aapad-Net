<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aapad-Net | Admin Panel</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-gray-900 text-white min-h-screen p-4">

    <div class="mb-6 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-3">
        <div>
            <h1 class="text-3xl font-bold text-red-500">🛠 Aapad-Net Control Panel</h1>
            <p class="text-gray-400 text-sm">Live Emergency Requests</p>
        </div>
        <a href="/logout"
            class="text-red-600 bg-gray-700 hover:bg-red-600 hover:text-white px-4 py-2 rounded-lg tracking-wide text-sm">
            Logout
        </a>
    </div>

    <div class="space-y-4">

        <% if (!requests || requests.length===0) { %>
            <div class="bg-gray-800 p-6 rounded-xl text-center text-gray-400">
                No active requests.
            </div>
            <% } else { %>
                <% requests.forEach(request=> { %>
                    <div class="bg-gray-800 rounded-2xl p-5 shadow-lg border border-gray-700">

                        <div class="flex justify-between items-start gap-4">
                            <div>
                                <h2 class="text-xl font-semibold">
                                    <%= request.name %>
                                </h2>
                                <p class="text-sm text-gray-400">
                                    <%= request.created_at %>
                                </p>
                            </div>

                            <div>
                                <% if (request.type==="medical" ) { %>
                                    <span class="bg-red-600 px-3 py-1 text-sm rounded-full">Critical</span>
                                    <% } else { %>
                                        <span
                                            class="bg-yellow-500 text-black px-3 py-1 text-sm rounded-full">High</span>
                                        <% } %>
                            </div>
                        </div>

                        <div class="mt-4 text-sm text-gray-300 space-y-1">
                            <p><strong>Type:</strong>
                                <%= request.type %>
                            </p>
                            <p><strong>Phone:</strong>
                                <%= request.phone || "Not provided" %>
                            </p>
                            <p><strong>Location:</strong>
                                <%= request.location || "Unknown" %>
                            </p>
                        </div>

                        <div class="mt-4 flex gap-3 flex-wrap">
                            <button class="bg-blue-600 hover:bg-blue-700 px-4 py-2 rounded-lg text-sm">
                                Mark In Progress
                            </button>
                            <button class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg text-sm">
                                Mark Resolved
                            </button>
                        </div>

                    </div>
                    <% }) %>
                        <% } %>

    </div>

</body>
<script src="https://cdn.tailwindcss.com"></script>

</html>