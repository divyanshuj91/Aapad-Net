<!DOCTYPE html>
<html>

<head>
    <title>Aapad-Net | Mark Safe</title>
    <link rel="stylesheet" href="/style.css">
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen flex items-center justify-center p-4">

    <div
        class="w-full max-w-md bg-gray-800/80 backdrop-blur p-8 rounded-3xl shadow-2xl border border-gray-700 space-y-6">

        <div class="text-center space-y-2">
            <h1 class="text-3xl font-bold text-green-400">🟢 Mark Yourself Safe</h1>
            <p class="text-sm text-gray-400">
                Notify rescue teams that you are safe and out of danger.
            </p>
        </div>

        <form id="safeForm" class="space-y-5">

            <div>
                <label class="block text-sm mb-2 text-gray-300">Full Name</label>
                <input type="text" id="name" required
                    class="w-full px-4 py-3 bg-gray-700 rounded-xl border border-gray-600 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition"
                    placeholder="Enter your name">
            </div>

            <div>
                <label class="block text-sm mb-2 text-gray-300">Current Location (Optional)</label>
                <input type="text" id="location"
                    class="w-full px-4 py-3 bg-gray-700 rounded-xl border border-gray-600 focus:ring-2 focus:ring-green-500 focus:border-green-500 outline-none transition"
                    placeholder="Nearby landmark or area">
            </div>

            <button id="submitBtn" type="submit"
                class="w-full bg-green-600 hover:bg-green-700 py-3 rounded-xl font-semibold text-lg transition duration-200">
                Confirm Safe Status
            </button>

        </form>

        <div class="text-center">
            <a href="/" class="text-sm text-gray-400 hover:text-white">
                ← Back to Home
            </a>
        </div>

    </div>

    <script>
        document.getElementById("safeForm").addEventListener("submit", async (e) => {
            e.preventDefault();

            const data = {
                name: document.getElementById("name").value,
                location: document.getElementById("location").value
            };

            await fetch("/safe", {
                method: "POST",
                headers: { "Content-Type": "application/json" },
                body: JSON.stringify(data)
            });

            alert("Your status has been marked safe.");
        });
    </script>

</body>

</html>