<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aapad-Net | Home</title>
    <link rel="stylesheet" href="/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">
</head>

<body class="font-sans bg-slate-900 min-h-screen flex flex-col">

    <div class="flex justify-between items-center px-4 sm:px-8 py-4 bg-slate-900 border-b border-slate-800 shadow-sm">

        <div class="text-xs sm:text-sm">
            <span class="text-slate-400">Status:</span>
            <span class="<%= statusClass %> font-bold tracking-wide">
                <%= status %>
            </span>
        </div>

        <div
            class="inline-flex items-center gap-3 bg-slate-800 border border-slate-700 px-5 py-2.5 rounded-full shadow-sm">

            <span class="text-red-500 text-sm font-bold tracking-wider">ADMIN?</span>
            <span class="text-slate-600">|</span>
            <a href="/login"
                class="text-cyan-400 hover:text-cyan-300 text-sm font-semibold transition flex items-center gap-1">

                Login here <span aria-hidden="true">→</span>
            </a>

        </div>

    </div>

    <main class="flex-1 flex flex-col items-center justify-center px-4 sm:px-6 py-10">

        <div class="text-center mb-10">
            <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-red-500 mb-2">
                Aapad<span class="text-slate-100">-Net</span>
            </h1>
            <h2 class="text-base sm:text-xl font-medium text-slate-400 mb-6">
                Disaster Response Portal
            </h2>
            <p class="text-slate-300 text-sm sm:text-base max-w-md mx-auto">
                Tell us your situation so we can respond quickly and effectively.
            </p>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 sm:gap-6 w-full max-w-3xl">

            <a href="/request"
                class="sm:col-span-2 bg-red-600 hover:bg-red-700 text-white py-6 sm:py-8 rounded-2xl shadow-xl 
              text-xl sm:text-2xl font-bold text-center transition transform hover:scale-[1.02] active:scale-95 animate-pulse">
                🚨 I Need Immediate Help
            </a>

            <a href="/safe" class="bg-green-600 hover:bg-green-700 text-white py-5 sm:py-6 rounded-2xl shadow-lg 
    text-lg sm:text-xl font-semibold text-center transition transform hover:scale-[1.02] active:scale-95 
    flex flex-col items-center justify-center leading-tight px-2">

                <span>✅ I Am Safe</span>
                <span class="text-sm font-medium opacity-80 mt-1">
                    (No Assistance Required)
                </span>

            </a>

            <a href="/report"
                class="bg-amber-500 hover:bg-amber-600 text-black py-5 sm:py-6 rounded-2xl shadow-lg 
    text-lg sm:text-xl font-semibold text-center transition transform hover:scale-[1.02] active:scale-95 flex flex-col items-center justify-center leading-tight px-2">
                <span>🚧 Report Hazard</span>
                <span class="text-sm font-medium opacity-80 mt-1">(Blocked Road / Danger)</span>
            </a>

            <a href="/assist"
                class="bg-cyan-600 hover:bg-cyan-700 text-black py-5 sm:py-6 rounded-2xl shadow-lg 
    text-lg sm:text-xl font-semibold text-center transition transform hover:scale-[1.02] active:scale-95 flex flex-col items-center justify-center leading-tight px-2">
                <span>🆘 Assist Others</span>
                <span class="text-sm font-medium opacity-80 mt-1">(Provide Help / Alert Authorities)</span>
            </a>

        </div>

    </main>

    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        if (
            window.location.hostname !== "192.168.137.1" &&
            window.location.hostname !== "localhost"
        ) {
            window.location.href = "http://192.168.137.1:3000";
        }
    </script>

</body>

</html>