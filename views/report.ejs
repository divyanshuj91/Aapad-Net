<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Report Hazard | Aapad-Net</title>
    <link rel="stylesheet" href="/style.css">
    <link href="https://fonts.googleapis.com/css2?family=Open+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
</head>
<body class="font-['Open_Sans'] bg-gray-50 text-gray-900 min-h-screen flex flex-col antialiased">

    <!-- Header -->
    <header class="bg-white border-b border-gray-100 px-4 sm:px-12 py-3.5 sm:py-5 flex justify-between items-center sticky top-0 z-50">
        <a href="/" class="text-lg sm:text-2xl font-bold tracking-tight text-gray-900">
            Aapad<span class="text-blue-600">-Net</span>
        </a>
        <a href="/" class="text-xs sm:text-sm font-medium text-gray-500 hover:text-black transition">
            &larr; Back
        </a>
    </header>

    <main class="flex-1 flex flex-col items-center py-6 sm:py-12 px-4 w-full">
        <div class="w-full max-w-lg bg-white rounded-xl sm:rounded-2xl shadow-sm border border-gray-200 p-5 sm:p-8">
            <h2 class="text-xl sm:text-2xl font-bold mb-1 sm:mb-2 text-gray-900">Report Hazard</h2>
            <p class="text-gray-500 text-xs sm:text-sm mb-6">Upload a photo to report obstructed roads, infrastructure damage, etc.</p>
            
            <form id="hazardForm" class="space-y-5">
                <!-- Camera / Upload -->
                <div>
                    <label class="block text-sm font-semibold mb-2 text-gray-900">Evidence Photo <span class="text-red-500">*</span></label>
                    <div class="flex flex-col items-center justify-center border-2 border-gray-200 border-dashed rounded-xl bg-gray-50 relative overflow-hidden min-h-[200px] sm:min-h-[250px]">
                        
                        <video id="camera-feed" class="w-full h-[200px] sm:h-[250px] object-cover hidden" autoplay playsinline></video>
                        <img id="image-preview" src="#" alt="Hazard Preview" class="w-full h-[200px] sm:h-[250px] object-cover hidden">
                        
                        <div id="upload-prompt" class="space-y-3 text-center p-4 sm:p-6 w-full">
                            <svg class="mx-auto h-8 w-8 sm:h-10 sm:w-10 text-gray-400" stroke="currentColor" fill="none" viewBox="0 0 48 48">
                                <path d="M14 14h20m-10 10A5 5 0 1024 14a5 5 0 000 10zm-10 8h20a2 2 0 002-2V12a2 2 0 00-2-2H14a2 2 0 00-2 2v14a2 2 0 002 2z" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                                <circle cx="24" cy="24" r="10" stroke="currentColor" stroke-width="2" />
                            </svg>
                            <div class="flex gap-2 w-full">
                                <button type="button" id="start-camera-btn" class="flex-1 bg-gray-900 hover:bg-black text-white font-medium py-2.5 px-3 rounded-lg shadow-sm transition flex items-center justify-center gap-1.5 text-xs sm:text-sm active:scale-95">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                                    Camera
                                </button>
                                <label for="image" class="flex-1 bg-white border border-gray-200 text-gray-700 hover:bg-gray-50 font-medium py-2.5 px-3 rounded-lg shadow-sm transition cursor-pointer text-center flex items-center justify-center text-xs sm:text-sm active:scale-95">
                                    Upload
                                </label>
                                <input id="image" name="image" type="file" accept="image/*" class="sr-only">
                            </div>
                        </div>

                        <div id="camera-controls" class="absolute bottom-3 left-0 right-0 flex justify-center gap-3 hidden">
                            <button type="button" id="capture-btn" class="bg-white text-gray-900 font-bold py-2 px-5 rounded-full shadow-lg border border-gray-200 text-sm active:scale-95 transition">Capture</button>
                            <button type="button" id="close-camera-btn" class="bg-gray-900/80 text-white font-medium py-2 px-4 rounded-full text-sm active:scale-95 transition">Cancel</button>
                        </div>

                        <div id="retake-controls" class="absolute bottom-3 left-0 right-0 flex justify-center hidden">
                            <button type="button" id="retake-btn" class="bg-white/90 text-gray-900 font-medium py-2 px-5 rounded-full shadow border border-gray-200 text-sm active:scale-95 transition">Retake</button>
                        </div>
                        
                        <canvas id="camera-canvas" class="hidden"></canvas>
                    </div>
                </div>

                <!-- Location -->
                <div>
                    <label class="block text-sm font-semibold mb-1.5 text-gray-900">Location <span class="text-red-500">*</span></label>
                    <input type="text" id="location" name="location" required
                        class="w-full bg-gray-50 border border-gray-200 rounded-xl px-3.5 py-2.5 sm:px-4 sm:py-3 text-sm text-gray-900 outline-none focus:border-blue-500 focus:bg-white transition"
                        placeholder="E.g., Near district hospital">
                </div>

                <!-- Description -->
                <div>
                    <label class="block text-sm font-semibold mb-1.5 text-gray-900">Description <span class="text-red-500">*</span></label>
                    <textarea id="description" name="description" rows="3" required
                        class="w-full bg-gray-50 border border-gray-200 rounded-xl px-3.5 py-2.5 sm:px-4 sm:py-3 text-sm text-gray-900 outline-none focus:border-blue-500 focus:bg-white transition resize-none"
                        placeholder="Describe the hazard..."></textarea>
                </div>

                <!-- Submit -->
                <button type="submit"
                    class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 sm:py-3.5 rounded-xl shadow-sm transition flex justify-center items-center gap-2 active:scale-[0.98]">
                    <span id="submit-text">Submit Report</span>
                    <span id="submit-spinner" class="hidden">
                        <svg class="animate-spin h-5 w-5 text-white" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                        </svg>
                    </span>
                </button>
            </form>
        </div>
    </main>

    <!-- Success Modal -->
    <div id="success-modal" class="fixed inset-0 bg-gray-900/40 backdrop-blur-sm flex items-end sm:items-center justify-center p-0 sm:p-4 z-50 hidden opacity-0 transition-opacity duration-300">
        <div class="bg-white rounded-t-2xl sm:rounded-2xl shadow-xl p-6 sm:p-8 w-full sm:max-w-sm text-center transform translate-y-4 sm:scale-95 transition-all duration-300">
            <div class="mx-auto flex items-center justify-center h-14 w-14 rounded-full bg-green-50 mb-5 text-green-500">
                <svg class="h-7 w-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                </svg>
            </div>
            <h3 class="text-lg sm:text-xl font-bold text-gray-900 mb-2">Report Submitted</h3>
            <p class="text-gray-500 text-sm mb-6">Your report has been logged successfully.</p>
            <a href="/" class="block w-full bg-gray-900 hover:bg-black text-white font-medium py-3 rounded-xl transition active:scale-[0.98]">
                Return to Home
            </a>
        </div>
    </div>

    <!-- Footer -->
    <footer class="border-t border-gray-100 py-5 sm:py-8 text-center text-xs sm:text-sm text-gray-400 mt-auto bg-white w-full">
        <p>Aapad-Net Platform &copy; 2026</p>
    </footer>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        const form = document.getElementById('hazardForm');
        const imageInput = document.getElementById('image');
        const uploadPrompt = document.getElementById('upload-prompt');
        const imagePreview = document.getElementById('image-preview');
        const video = document.getElementById('camera-feed');
        const canvas = document.getElementById('camera-canvas');
        const startCameraBtn = document.getElementById('start-camera-btn');
        const captureBtn = document.getElementById('capture-btn');
        const closeCameraBtn = document.getElementById('close-camera-btn');
        const retakeBtn = document.getElementById('retake-btn');
        const cameraControls = document.getElementById('camera-controls');
        const retakeControls = document.getElementById('retake-controls');
        const submitBtn = form.querySelector('button[type="submit"]');
        const submitText = document.getElementById('submit-text');
        const submitSpinner = document.getElementById('submit-spinner');
        const successModal = document.getElementById('success-modal');
        let stream = null;
        let capturedFile = null;

        imageInput.addEventListener('change', function() {
            const file = this.files[0];
            if (file) {
                capturedFile = file;
                const reader = new FileReader();
                reader.onload = function(e) {
                    imagePreview.src = e.target.result;
                    imagePreview.classList.remove('hidden');
                    uploadPrompt.classList.add('hidden');
                    retakeControls.classList.remove('hidden');
                }
                reader.readAsDataURL(file);
            }
        });

        startCameraBtn.addEventListener('click', async () => {
            try {
                stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
                video.srcObject = stream;
                video.classList.remove('hidden');
                uploadPrompt.classList.add('hidden');
                cameraControls.classList.remove('hidden');
                retakeControls.classList.add('hidden');
                imagePreview.classList.add('hidden');
            } catch (err) {
                alert("Could not access camera. Please use 'Upload' instead.");
            }
        });

        captureBtn.addEventListener('click', () => {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            canvas.getContext('2d').drawImage(video, 0, 0, canvas.width, canvas.height);
            const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
            imagePreview.src = dataUrl;
            canvas.toBlob((blob) => {
                capturedFile = new File([blob], "captured_hazard.jpg", { type: "image/jpeg" });
            }, 'image/jpeg', 0.8);
            stopCamera();
            video.classList.add('hidden');
            cameraControls.classList.add('hidden');
            imagePreview.classList.remove('hidden');
            retakeControls.classList.remove('hidden');
        });

        closeCameraBtn.addEventListener('click', () => {
            stopCamera();
            video.classList.add('hidden');
            cameraControls.classList.add('hidden');
            uploadPrompt.classList.remove('hidden');
        });

        retakeBtn.addEventListener('click', () => {
            imagePreview.classList.add('hidden');
            retakeControls.classList.add('hidden');
            uploadPrompt.classList.remove('hidden');
            capturedFile = null;
            imageInput.value = '';
        });

        function stopCamera() {
            if (stream) { stream.getTracks().forEach(track => track.stop()); stream = null; }
        }

        form.addEventListener('submit', async (e) => {
            e.preventDefault();
            submitBtn.disabled = true;
            submitBtn.classList.add('opacity-50', 'cursor-not-allowed');
            submitText.classList.add('hidden');
            submitSpinner.classList.remove('hidden');

            const formData = new FormData();
            formData.append('location', document.getElementById('location').value);
            formData.append('description', document.getElementById('description').value);
            if (capturedFile) {
               formData.append('image', capturedFile);
            } else {
               alert("Please capture or upload a photo.");
               resetSubmitButton();
               return;
            }

            try {
                const res = await fetch('/report', { method: 'POST', body: formData });
                const data = await res.json();
                if (data.success) {
                    successModal.classList.remove('hidden');
                    setTimeout(() => {
                        successModal.classList.remove('opacity-0');
                        const modal = successModal.querySelector('div');
                        modal.classList.remove('translate-y-4', 'scale-95');
                        modal.classList.add('translate-y-0', 'scale-100');
                    }, 50);
                } else {
                    alert(data.message || 'Error submitting report.');
                    resetSubmitButton();
                }
            } catch (error) {
                alert('Connection failed. Please retry.');
                resetSubmitButton();
            }
        });

        function resetSubmitButton() {
            submitBtn.disabled = false;
            submitBtn.classList.remove('opacity-50', 'cursor-not-allowed');
            submitText.classList.remove('hidden');
            submitSpinner.classList.add('hidden');
        }
    </script>
</body>
</html>