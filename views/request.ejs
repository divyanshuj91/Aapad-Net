<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aapad-Net | Emergency Request</title>
    <link rel="stylesheet" href="/style.css">
</head>

<body class="bg-gray-900 text-white min-h-screen flex sm:items-center justify-center sm:p-4">

    <div
        class="w-full min-h-screen sm:min-h-0 sm:max-w-md bg-gray-800 sm:rounded-2xl shadow-xl p-6 sm:p-8 space-y-6 flex flex-col justify-center">

        <!-- Header -->
        <div class="text-center">
            <h1 class="text-3xl font-bold text-red-500 tracking-wide">🚨 Emergency Request</h1>
            <p class="text-sm text-gray-400 mt-2">
                Submit only if immediate assistance is required
            </p>
        </div>

        <!-- Form -->
        <form id="form" class="space-y-4">

            <!-- Name -->
            <div>
                <label class="block text-sm mb-1 text-gray-300">Full Name</label>
                <input type="text" id="name" required
                    class="w-full px-4 py-3 bg-gray-700 rounded-lg border border-gray-600 focus:ring-2 focus:ring-red-500 outline-none"
                    placeholder="Your name">
            </div>

            <!-- Contact -->
            <div>
                <label class="block text-sm mb-1 text-gray-300">Phone Number</label>
                <input type="tel" id="phone"
                    class="w-full px-4 py-3 bg-gray-700 rounded-lg border border-gray-600 focus:ring-2 focus:ring-red-500 outline-none"
                    placeholder="Optional but recommended">
            </div>

            <!-- Type of Help -->
            <div>
                <label class="block text-sm mb-2 text-gray-300">Type of Assistance Needed</label>
                <select id="type"
                    class="w-full px-4 py-3 bg-gray-700 rounded-lg border border-gray-600 focus:ring-2 focus:ring-red-500 outline-none">
                    <option value="medical">Medical Emergency</option>
                    <option value="food">Food & Water</option>
                    <option value="rescue">Rescue Required</option>
                    <option value="shelter">Shelter Needed</option>
                </select>
            </div>

            <!-- Location -->
            <div>
                <label class="block text-sm mb-1 text-gray-300">Current Location / Landmark</label>
                <textarea id="location" rows="2"
                    class="w-full px-4 py-3 bg-gray-700 rounded-lg border border-gray-600 focus:ring-2 focus:ring-red-500 outline-none"
                    placeholder="Describe nearby landmark"></textarea>
            </div>

            <!-- Urgency -->
            <div>
                <label class="block text-sm mb-2 text-gray-300">Urgency Level</label>

                <!-- Hidden input to store selected value -->
                <input type="hidden" id="urgency" name="urgency" value="">

                <div class="flex gap-3">
                    <button type="button" data-value="high"
                        class="urgency-btn flex-1 bg-gray-700 py-2 rounded-lg font-semibold border border-gray-600">
                        High
                    </button>

                    <button type="button" data-value="critical"
                        class="urgency-btn flex-1 bg-gray-700 py-2 rounded-lg font-semibold border border-gray-600">
                        Critical
                    </button>
                </div>
            </div>
            <!-- Camera / Upload Source -->
            <div>
                <label class="block text-sm font-medium mb-2 text-gray-300">Provide a Photo (Optional)</label>
                <div
                    class="mt-1 flex flex-col items-center justify-center border-2 border-gray-600 border-dashed rounded-xl hover:border-red-500 transition-colors bg-gray-900/50 relative overflow-hidden min-h-[250px] w-full">

                    <video id="camera-feed" class="w-full h-[250px] object-cover hidden" autoplay playsinline></video>

                    <img id="previewImage" src="#" alt="Emergency Preview" class="w-full h-[250px] object-cover hidden">

                    <div id="upload-prompt" class="space-y-4 text-center p-6 w-full">
                        <span class="text-4xl text-gray-400">📷</span>
                        <div class="flex flex-col gap-3 max-w-xs mx-auto">
                            <button type="button" id="start-camera-btn"
                                class="w-full bg-red-600 hover:bg-red-700 text-white font-medium py-2 rounded-lg transition flex items-center justify-center gap-2">
                                📸 Open Camera
                            </button>
                            <label for="image"
                                class="w-full bg-gray-700 hover:bg-gray-600 text-white font-medium py-2 rounded-lg transition cursor-pointer text-center">
                                🖼️ Upload from Gallery
                            </label>
                            <input id="image" name="image" type="file" accept="image/*" class="sr-only">
                        </div>
                    </div>

                    <div id="camera-controls"
                        class="absolute bottom-4 left-0 right-0 flex justify-center gap-4 hidden px-4 w-full">
                        <button type="button" id="capture-btn"
                            class="bg-white text-gray-900 font-bold py-2 px-6 rounded-full shadow-lg hover:bg-gray-200 transition">
                            Snap Photo
                        </button>
                        <button type="button" id="close-camera-btn"
                            class="bg-gray-800/80 text-white font-medium py-2 px-4 rounded-full border border-gray-600 shadow hover:bg-gray-700 transition">
                            Cancel
                        </button>
                    </div>

                    <div id="retake-controls"
                        class="absolute bottom-4 left-0 right-0 flex justify-center hidden w-full px-4">
                        <button type="button" id="retake-btn"
                            class="bg-gray-900/80 backdrop-blur text-white font-medium py-2 px-6 rounded-full border border-gray-600 shadow-lg hover:bg-gray-800 transition">
                            Retake Photo
                        </button>
                    </div>

                    <canvas id="camera-canvas" class="hidden"></canvas>
                </div>
            </div>

            <!-- Submit -->
            <button type="submit"
                class="w-full bg-red-600 hover:bg-red-700 transition py-3 rounded-xl font-bold text-lg">
                Send Emergency Alert
            </button>

        </form>

        <!-- Back -->
        <div class="text-center">
            <a href="/" class="text-sm text-gray-400 hover:text-white">← Back to Status</a>
        </div>

    </div>

    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        const buttons = document.querySelectorAll(".urgency-btn");
        const hiddenInput = document.getElementById("urgency");
        const form = document.getElementById("form");
        const imageInput = document.getElementById("image");
        const previewImage = document.getElementById("previewImage");
        const uploadPrompt = document.getElementById("upload-prompt");

        // Camera elements
        const video = document.getElementById("camera-feed");
        const canvas = document.getElementById("camera-canvas");
        const startCameraBtn = document.getElementById("start-camera-btn");
        const captureBtn = document.getElementById("capture-btn");
        const closeCameraBtn = document.getElementById("close-camera-btn");
        const retakeBtn = document.getElementById("retake-btn");
        const cameraControls = document.getElementById("camera-controls");
        const retakeControls = document.getElementById("retake-controls");

        let stream = null;
        let selectedFile = null;

        buttons.forEach(btn => {
            btn.addEventListener("click", () => {
                buttons.forEach(b => {
                    b.classList.remove("bg-yellow-500", "bg-red-600", "text-black", "text-white");
                    b.classList.add("bg-gray-700", "text-white");
                });

                if (btn.dataset.value === "high") {
                    btn.classList.remove("bg-gray-700", "text-white");
                    btn.classList.add("bg-yellow-500", "text-black");
                } else if (btn.dataset.value === "critical") {
                    btn.classList.remove("bg-gray-700");
                    btn.classList.add("bg-red-600", "text-white");
                }

                hiddenInput.value = btn.dataset.value;
            });
        });

        // 1. File Upload Logic
        imageInput.addEventListener('change', function () {
            const file = this.files[0];
            if (file) {
                selectedFile = file;
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImage.src = e.target.result;
                    previewImage.classList.remove('hidden');
                    uploadPrompt.classList.add('hidden');
                    retakeControls.classList.remove('hidden');
                }
                reader.readAsDataURL(file);
            }
        });

        // 2. Start Live Camera
        startCameraBtn.addEventListener('click', async () => {
            try {
                stream = await navigator.mediaDevices.getUserMedia({
                    video: { facingMode: 'environment' }
                });
                video.srcObject = stream;

                video.classList.remove('hidden');
                uploadPrompt.classList.add('hidden');
                cameraControls.classList.remove('hidden');
                retakeControls.classList.add('hidden');
                previewImage.classList.add('hidden');
            } catch (err) {
                console.error("Camera Error:", err);
                alert("Could not access camera. Please allow camera permissions or use 'Upload from Gallery'.");
            }
        });

        // 3. Capture Photo
        captureBtn.addEventListener('click', () => {
            canvas.width = video.videoWidth;
            canvas.height = video.videoHeight;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(video, 0, 0, canvas.width, canvas.height);

            const dataUrl = canvas.toDataURL('image/jpeg', 0.8);
            previewImage.src = dataUrl;

            canvas.toBlob((blob) => {
                selectedFile = new File([blob], "captured_emergency.jpg", { type: "image/jpeg" });
            }, 'image/jpeg', 0.8);

            stopCamera();

            video.classList.add('hidden');
            cameraControls.classList.add('hidden');
            previewImage.classList.remove('hidden');
            retakeControls.classList.remove('hidden');
        });

        // 4. Close Camera
        closeCameraBtn.addEventListener('click', () => {
            stopCamera();
            video.classList.add('hidden');
            cameraControls.classList.add('hidden');
            uploadPrompt.classList.remove('hidden');
        });

        // 5. Retake Photo
        retakeBtn.addEventListener('click', () => {
            previewImage.classList.add('hidden');
            retakeControls.classList.add('hidden');
            uploadPrompt.classList.remove('hidden');
            selectedFile = null;
            imageInput.value = '';
        });

        function stopCamera() {
            if (stream) {
                stream.getTracks().forEach(track => track.stop());
                stream = null;
            }
        }

        // 3. Handle Form Submission
        form.addEventListener("submit", async (e) => {
            e.preventDefault();

            const formData = new FormData();
            formData.append("name", document.getElementById("name").value);
            formData.append("phone", document.getElementById("phone").value);
            formData.append("type", document.getElementById("type").value);
            formData.append("location", document.getElementById("location").value);
            formData.append("urgency", hiddenInput.value);

            if (selectedFile) {
                formData.append("image", selectedFile);
            }

            if (!hiddenInput.value && !document.getElementById("type").value) {
                alert("Please select urgency level");
                return;
            }

            try {
                const response = await fetch("/request", {
                    method: "POST",
                    body: formData
                });

                if (response.ok) {
                    alert("Emergency Alert Sent!");
                    form.reset();
                } else {
                    alert("Failed to send alert.");
                }

            } catch (error) {
                console.error("Error:", error);
                alert("Server error.");
            }
        });
    </script>

</body>

</html>